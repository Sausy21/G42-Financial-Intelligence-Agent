# Required — Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_...

# LLM model (Groq-hosted — no download needed)
# Options: llama-3.1-8b-instant (default, fastest)
#          llama-3.3-70b-versatile (highest quality)
#          mixtral-8x7b-32768, gemma2-9b-it
AGENT_MODEL=llama-3.1-8b-instant

# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Anomaly detection z-score threshold
ANOMALY_Z_THRESHOLD=2.5
MAX_RETRIEVAL_RESULTS=5

# Optional — PostgreSQL with pgvector (defaults to in-memory FAISS)
# PGVECTOR_URL=postgresql://user:pass@localhost:5432/financial_agent
